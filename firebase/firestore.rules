rules_version = '2';
service cloud.firestore {
	match /databases/{database}/documents {

		// Platform-level custom roles (admin-only write)
		match /platform/roles/custom/{roleId} {
			allow read: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
			allow write: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
		}

		// Admins collection (admin can read/write their own doc, superadmin can manage all)
		match /admins/{userId} {
			allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin');
		}

		// Tenants collection (tenant isolation)
		match /tenants/{tenantId} {
			allow read: if isTenantMember(tenantId);
			allow write: if isTenantAdmin(tenantId);
      
			// Members subcollection
			match /members/{memberId} {
				allow read: if isTenantMember(tenantId);
				allow write: if request.auth != null && request.auth.uid == memberId && isTenantAdmin(tenantId);
			}
			// Other tenant subcollections (e.g., agents, calls, etc.)
			match /{subCol=**}/{docId} {
				allow read: if isTenantMember(tenantId);
				allow write: if isTenantAdmin(tenantId);
			}
		}

		// Helper functions
		function isTenantMember(tenantId) {
			return request.auth != null &&
				exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
		}
		function isTenantAdmin(tenantId) {
			return request.auth != null &&
				get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
		}
	}
}
