rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Platform-level custom roles (admin-only) ──────────────────────────
    match /platform/roles/custom/{roleId} {
      allow read, write: if isAdmin();
    }

    // ── Platform config / metrics (admin-only write, server reads) ────────
    match /platform/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admins collection ─────────────────────────────────────────────────
    match /admins/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    // ── Feature flags (admin-only write, server-side reads) ───────────────
    match /featureFlags/{flagId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Available integrations catalog ────────────────────────────────────
    match /available_integrations/{integrationId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Audit log (append-only via server; no client writes) ─────────────
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false; // server-side only via admin SDK
    }

    // ── Processed events (idempotency; server only) ───────────────────────
    match /processedEvents/{eventId} {
      allow read, write: if false; // server-side only
    }

    // ── Tenants ───────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      // Fix 3: Allow a newly signed-up user to create their OWN tenant document.
      // The document ID must match their Firebase UID, and only a minimal set of
      // fields are permitted (plan defaults, email, name).  The subcollection
      // members doc doesn't exist yet at signup so we can't use isTenantMember().
      allow create: if request.auth != null
        && request.auth.uid == tenantId
        && request.resource.data.keys().hasOnly(
            ['name', 'email', 'plan', 'createdAt', 'minutesUsed',
             'minutesLimit', 'onboardingComplete', 'businessType', 'timezone'])
        && request.resource.data.plan == 'starter';

      // Reads: tenant members or admins.
      allow read: if isTenantMember(tenantId) || isAdmin();

      // Updates: tenant admins/owners, or the server (admin SDK bypasses rules).
      allow update: if isTenantAdmin(tenantId) || isAdmin();

      // Delete: superadmin only (handled via admin SDK in practice).
      allow delete: if isAdmin();

      // ── Members subcollection ─────────────────────────────────────────
      match /members/{memberId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        // Members can update their own doc; tenant admins can manage all members.
        allow write: if (request.auth != null && request.auth.uid == memberId)
          || isTenantAdmin(tenantId)
          || isAdmin();
      }

      // ── Agents subcollection ──────────────────────────────────────────
      match /agents/{agentId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        allow write: if isTenantAdmin(tenantId) || isAdmin();
      }

      // ── Calls subcollection ───────────────────────────────────────────
      match /calls/{callId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        // Calls are written by server webhooks only; no client writes.
        allow write: if false;
      }

      // ── Invoices subcollection ────────────────────────────────────────
      match /invoices/{invoiceId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        // Invoices are written by server webhooks only.
        allow write: if false;
      }

      // ── Integrations subcollection ────────────────────────────────────
      match /integrations/{integrationId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        allow write: if isTenantAdmin(tenantId) || isAdmin();
      }

      // ── Catch-all for any other subcollections ────────────────────────
      match /{subCollection}/{docId} {
        allow read: if isTenantMember(tenantId) || isAdmin();
        allow write: if isTenantAdmin(tenantId) || isAdmin();
      }
    }

    // ── Helper functions ──────────────────────────────────────────────────

    function isAdmin() {
      // Admins are identified by a "role: admin" custom claim on their Firebase token.
      return request.auth != null &&
        request.auth.token.get('role', 'user') == 'admin';
    }

    function isTenantMember(tenantId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function isTenantAdmin(tenantId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
          .data.role in ['owner', 'admin'];
    }
  }
}
